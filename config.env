# =============================================================================
# Example Agent VS — Configuration
# =============================================================================
#
# This file is read by the setup/start scripts, Docker Compose, and GHA workflow.
# It contains all configuration needed for the Example Agent service.
#
# For local testing:
#   source config.env
#   ./scripts/setup.sh
#
# =============================================================================

# ---------------------------------------------------------------------------
# Network (derived from branch name in GHA; set manually for local usage)
# ---------------------------------------------------------------------------
# NETWORK="testnet"

# ---------------------------------------------------------------------------
# Agent public URL (used to check existing credentials on the DID document)
# For student-deployed agents, the URL must follow this convention:
#   https://<agentname>.agents.<team_name>.teams.eafit.testnet.verana.network
# ---------------------------------------------------------------------------
AGENT_PUBLIC_URL="${AGENT_PUBLIC_URL:-https://agent.eafit.testnet.verana.network}"

# ---------------------------------------------------------------------------
# Organization — parent service (eafit-challenge)
# The admin API is used to request Service credentials.
# ---------------------------------------------------------------------------
ORG_VS_PUBLIC_URL="${ORG_VS_PUBLIC_URL:-https://organization.eafit.testnet.verana.network}"
ORG_VS_PUBLIC_URL="${ORG_VS_PUBLIC_URL%/}"
ORG_VS_ADMIN_URL="${ORG_VS_ADMIN_URL:-https://admin.organization.eafit.testnet.verana.network}"
ORG_VS_ADMIN_URL="${ORG_VS_ADMIN_URL%/}"

# ---------------------------------------------------------------------------
# VS Agent image and ports (local development)
# Use different ports than organization (3000/3001) and avatar (3002/3003).
# ---------------------------------------------------------------------------
VS_AGENT_IMAGE="${VS_AGENT_IMAGE:-veranalabs/vs-agent:latest}"
VS_AGENT_CONTAINER_NAME="example-agent"
VS_AGENT_ADMIN_PORT="3010"
VS_AGENT_PUBLIC_PORT="3011"

# ---------------------------------------------------------------------------
# Service details
# These appear in the Service credential issued by organization.
# ---------------------------------------------------------------------------
SERVICE_NAME="Example Github Agent"
SERVICE_TYPE="AIAgent"
SERVICE_DESCRIPTION="Example AI agent for the EAFIT Challenge with GitHub MCP integration"
SERVICE_LOGO_URL="https://hologram.zone/images/github.svg"
SERVICE_MIN_AGE="0"
SERVICE_TERMS="https://verana.io/terms"
SERVICE_PRIVACY="https://verana.io/privacy"

# ---------------------------------------------------------------------------
# Chatbot configuration (hologram-generic-ai-agent)
# ---------------------------------------------------------------------------
CHATBOT_IMAGE="${CHATBOT_IMAGE:-io2060/hologram-generic-ai-agent-app:v1.11.2}"
CHATBOT_PORT="3003"

# LLM
LLM_PROVIDER=openai
OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=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

# RAG
RAG_PROVIDER="langchain"
RAG_DOCS_PATH="/app/rag/docs"

# Memory
AGENT_MEMORY_BACKEND="redis"
AGENT_MEMORY_WINDOW="20"

# ---------------------------------------------------------------------------
# Credential authentication (eafit-challenge avatar credDef)
# AnonCreds credential definition ID used to authenticate users.
# This is the credDef registered by the eafit-challenge avatar service.
# ---------------------------------------------------------------------------
CREDENTIAL_DEFINITION_ID="did:webvh:QmPZBrmehNXxY4eRL2a9F52sCfkQfToPHM8R427sNS2F1N:avatar.eafit.testnet.verana.network/resources/zQmdzYfqKe6ypc9NbRMHbCFvgnrqCwbWjBK2odKYrRePaTu"

# GitHub MCP
GITHUB_MCP_URL="https://api.githubcopilot.com/mcp/"

# MCP config encryption
MCP_CONFIG_ENCRYPTION_KEY="${MCP_CONFIG_ENCRYPTION_KEY:-}"

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD="${POSTGRES_PASSWORD:-changeme}"
POSTGRES_USER="example_agent_db"
POSTGRES_DB="example-agent"

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL="info"
